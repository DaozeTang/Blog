---
layout: base.liquid
navTitle: Archive
pagination:
  data: collections.categories
  size: 1
  alias: term
permalink: "/categories/{{ term.slug }}/"
eleventyComputed:
  title: "{{ term.name }}"
eleventyExcludeFromCollections: true
---

<header class="page-header">
    <p class="page-header-kicker kicker">Category</p>
    <h1 class="page-header-title">{{ term.name }}<span class="title-dot">.</span></h1>
    <div class="page-header-meta">
        <span class="page-header-stat"><i class="far fa-file-lines" aria-hidden="true"></i> {{ term.items.size }} post{% if term.items.size > 1 %}s{% endif %}</span>
        <a class="page-header-stat" href="/archive/"><i class="fas fa-arrow-left" aria-hidden="true"></i> All posts</a>
    </div>
</header>

<section class="section post-feed">
    {% assign posts = term.items %}
    {% include "post-list" %}
</section>
