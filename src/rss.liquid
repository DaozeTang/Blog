---
permalink: /rss.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/">
  <channel>
    <title>{{ site.title | xmlEscape }}</title>
    <link>{{ site.url }}/</link>
    <atom:link href="{{ site.url }}/rss.xml" rel="self" type="application/rss+xml" />
    <description>{{ site.description | xmlEscape }}</description>
    <language>{{ site.lang }}</language>
    <generator>Eleventy</generator>
    <copyright>© {{ site.start_year }}–{{ "now" | date: "%Y" }} {{ site.author.name }}</copyright>
    {% if collections.posts.size > 0 %}<lastBuildDate>{{ collections.posts.first.data.published | rfc822 }}</lastBuildDate>{% endif %}
    {% for post in collections.posts limit: 20 %}
    <item>
      <title>{{ post.data.title | xmlEscape }}</title>
      <link>{{ post.url | encodeUri | prepend: site.url }}</link>
      <guid isPermaLink="true">{{ post.url | encodeUri | prepend: site.url }}</guid>
      <pubDate>{{ post.data.published | rfc822 }}</pubDate>
      {% if post.data.category and post.data.category != "" %}<category>{{ post.data.category | xmlEscape }}</category>{% endif %}
      {% if post.data.description and post.data.description != "" %}<description>{{ post.data.description | xmlEscape }}</description>{% endif %}
      <content:encoded>{{ post.templateContent | absoluteHtml: site.url | cdata }}</content:encoded>
    </item>
    {% endfor %}
  </channel>
</rss>
