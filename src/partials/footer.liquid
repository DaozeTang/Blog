<footer class="site-footer">
    <div class="shell">
        <div class="footer-base">
            <div class="footer-note">{{ site.footer_text }}</div>
            <div class="footer-meta">
                <span>&copy; {{ site.start_year }}&ndash;{{ "now" | date: "%Y" }} {{ site.author.name }}</span>
                <span class="sep" aria-hidden="true">&#10038;</span>
                <a href="/rss.xml">RSS</a>
                <span class="sep" aria-hidden="true">&#10038;</span>
                <a href="/sitemap.xml">Sitemap</a>
            </div>
        </div>
    </div>
</footer>
