<ol class="post-list">
    {% for post in posts %}
    <li class="post-item">
        <div class="post-item-date mono">
            {% if post.data.pinned %}<i class="fas fa-thumbtack post-pin" aria-label="Pinned" title="Pinned"></i>{% endif %}
            {{ post.data.published | readableDate }}
        </div>
        <div class="post-item-main">
            <h2 class="post-item-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
            {% if post.data.description and post.data.description != "" %}
            <p class="post-item-desc">{{ post.data.description }}</p>
            {% endif %}
            <div class="post-item-meta">
                {% if post.data.category and post.data.category != "" %}
                <a class="post-chip post-chip-cat" href="/categories/{{ post.data.category | ghSlug }}/">{{ post.data.category }}</a>
                {% endif %}
                {% for tag in post.data.tags %}
                <a class="post-chip" href="/tags/{{ tag | ghSlug }}/"><span class="post-chip-hash">#</span>{{ tag }}</a>
                {% endfor %}
                <span class="post-item-read">{{ post.templateContent | readingTime }}</span>
            </div>
        </div>
    </li>
    {% endfor %}
</ol>
