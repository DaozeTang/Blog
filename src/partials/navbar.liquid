<header class="site-header" id="site-header">
    <div class="shell">
        <nav class="topbar" id="topbar" aria-label="Main navigation">
            <a class="brand" href="/">
                <span class="brand-seal" aria-hidden="true">{{ site.author.name | slice: 0, 1 }}{{ site.author.name | split: " " | last | slice: 0, 1 }}</span>
                <span class="brand-name">{{ site.author.name }}</span>
            </a>

            <div class="nav-links" id="site-nav">
                {% for item in navigation.pages %}
                <a class="nav-link {% if item.name == navTitle %}active{% endif %}" href="{{ item.url }}">{{ item.name }}</a>
                {% endfor %}
                {% for item in navigation.external %}
                <a class="nav-link nav-link-ext" href="{{ item.url }}" target="_blank" rel="noopener">{{ item.name }}<i class="fas fa-arrow-up-right-from-square" aria-hidden="true"></i></a>
                {% endfor %}
            </div>

            <div class="nav-actions">
                <a class="theme-toggle nav-search-btn" id="nav-search-btn" href="/search/" aria-label="Search posts">
                    <i class="fas fa-magnifying-glass" aria-hidden="true"></i>
                </a>
                <button class="theme-toggle" type="button" id="theme-toggle" aria-label="Toggle dark mode" aria-pressed="false">
                    <i class="fas fa-moon" aria-hidden="true"></i>
                </button>
                <button class="nav-burger" type="button" id="nav-burger" aria-label="Toggle navigation" aria-expanded="false" aria-controls="site-nav">
                    <i class="fas fa-bars" aria-hidden="true"></i>
                </button>
            </div>
        </nav>
    </div>
</header>

<dialog class="search-dialog" id="search-dialog">
    <button class="dialog-close" type="button" data-dialog-close aria-label="Close search">&times;</button>
    <div class="pagefind-box" id="navbar-search"></div>
</dialog>
